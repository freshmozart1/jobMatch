{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path // empty' | { read -r f; [ -n \"$f\" ] && ./node_modules/.bin/prettier --write --experimental-cli \"$f\"; } 2>/dev/null || true"
          }
        ]
      }
    ]
  }
}
